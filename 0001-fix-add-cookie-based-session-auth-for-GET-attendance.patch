+                "RequestSource": "iOS"
+            };
+            console.log("    => [DEBUG] GET Request Headers: " + JSON.stringify(getHeaders, null, 2));
+
+            // Log session cookies
+            const cookies = await sessionContext.storageState();
+            console.log("    => [DEBUG] Session Cookies: " + JSON.stringify(cookies.cookies.map(c => ({ name: c.name, domain: c.domain, path: c.path })), null, 2));
+
+            // GET Request using the exact same sessionContext (Cookies handle auth like Postman)
             const verifyResponse = await sessionContext.get(getUrlPath, {
-                headers: {
-                    "Authorization": authToken,
-                    "Accept": "application/json",
-                    "RequestSource": "iOS",
