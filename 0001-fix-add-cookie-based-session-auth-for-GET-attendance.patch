-                    "ProviderCode": loginCredentials.providerCode,
-                    "X-Provider": loginCredentials.providerCode,
-                    "App-Version": "1.0"
-                }
+                headers: getHeaders,
+                timeout: 60000
             });
 
+            console.log("    => [DEBUG] GET Response Status: " + verifyResponse.status() + " " + verifyResponse.statusText());
+
+            // Log response headers
+            const respHeaders = verifyResponse.headers();
+            console.log("    => [DEBUG] GET Response Headers: " + JSON.stringify(respHeaders, null, 2));
+
+            // Log response body
+            try {
+                const respBody = await verifyResponse.text();
